  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@index([searchQuery], map: "idx_search_histories_query")
  @@index([createdAt], map: "idx_search_histories_created_at")
  @@index([searchType], map: "idx_search_histories_type")
