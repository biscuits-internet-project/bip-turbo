model Track {
  id              String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  showId          String                   @map("show_id") @db.Uuid
  songId          String                   @map("song_id") @db.Uuid
  set             String                   @db.VarChar
  position        Int
  segue           String?                  @db.VarChar
  createdAt       DateTime                 @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime                 @updatedAt @map("updated_at") @db.Timestamp(6)
  likesCount      Int                      @default(0) @map("likes_count")
  slug            String?                  @unique(map: "tracks_slug_unique") @db.VarChar
  note            String?                  @db.VarChar
  allTimer        Boolean?                 @default(false) @map("all_timer")
  previousTrackId String?                  @map("previous_track_id") @db.Uuid
  nextTrackId     String?                  @map("next_track_id") @db.Uuid
  averageRating   Float?                   @default(0) @map("average_rating")
  ratingsCount    Int                      @default(0) @map("ratings_count")
  searchText      String?                  @map("search_text") @db.Text
  searchVector    Unsupported("tsvector")? @map("search_vector")
  gap                       Int?
  previousPerformanceShowId String?         @map("previous_performance_show_id") @db.Uuid
  duration        Int?
  durationSource  String?                  @map("duration_source") @db.VarChar
  annotations     Annotation[]
  show            Show                     @relation(fields: [showId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_tracks_shows_show_id")
  song            Song                     @relation(fields: [songId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_tracks_songs_song_id")
  previousPerformanceShow   Show?           @relation("TrackPreviousPerformance", fields: [previousPerformanceShowId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_tracks_previous_performance_show_id")
  durationSourceRef         DurationSource? @relation(fields: [durationSource], references: [name], onDelete: NoAction, onUpdate: NoAction, map: "fk_tracks_duration_source")
  trackMusicians            TrackMusician[]
  trackFlags                TrackFlagAssignment[]
  segueRecurrences          TrackSegueRecurrence[]
  completionAsEarlier       TrackCompletion?  @relation("CompletionEarlier")
  completionsAsLater        TrackCompletion[] @relation("CompletionLater")

  @@index([likesCount])
  @@index([nextTrackId])
  @@index([previousTrackId])
  @@index([songId])
  @@index([previousPerformanceShowId])
  @@index([showId, set, position], map: "tracks_show_set_position_idx")
  @@map("tracks")
}

/// Canonical list of where a Track.duration came from. A lookup table (rather
/// than a bare string column) so the values are defined in one place and the
/// FK rejects typos. The `name` is the natural key the app code writes
/// ("nugs" | "archive" | "manual").
model DurationSource {
  name        String   @id @db.VarChar
  description String?  @db.VarChar
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  tracks      Track[]

  @@map("duration_sources")
}

/// Structured performance markers on a track, replacing free-text annotation
/// parsing for the dyslexic/inverted/unfinished filters. An enum (not a string
/// column) so the vocabulary is fixed in one place and adding a value is a
/// single migration.
enum TrackFlag {
  DYSLEXIC
  INVERTED
  UNFINISHED
  ENDING_ONLY
  MIDDLE_ONLY
  BEGINNING_ONLY

  @@map("track_flag")
}

/// Join table giving a track its set of TrackFlags. One row per (track, flag).
/// The recurrence of THIS flag for the song: `flagVersionGap` = versions of the
/// song between this flagged performance and the prior flagged one (the gating
/// denominator), `flagGap` = shows between (kept for reference), and
/// `flagPreviousShowId` the prior flagged show (null ⇒ first time this flag
/// applied). Derived by the stats rebuild, not entered by hand.
model TrackFlagAssignment {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trackId            String    @map("track_id") @db.Uuid
  flag               TrackFlag
  flagGap            Int?      @map("flag_gap")
  flagVersionGap     Int?      @map("flag_version_gap")
  flagPreviousShowId String?   @map("flag_previous_show_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  track            Track @relation(fields: [trackId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_track_flags_tracks_track_id")
  flagPreviousShow Show? @relation("TrackFlagPreviousShow", fields: [flagPreviousShowId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_track_flags_previous_show_id")

  @@unique([trackId, flag], map: "track_flags_track_flag_unique")
  @@index([flag])
  @@index([flagPreviousShowId])
  @@map("track_flags")
}

/// The three segue-shape recurrence series a track can belong to. See
/// SegueRecurrenceKind in @bip/domain for the semantics.
enum SegueRecurrenceKind {
  STANDALONE
  NOT_SEGUED_IN
  NOT_SEGUED_OUT

  @@map("segue_recurrence_kind")
}

/// Recurrence of a track's segue shape (standalone / not-segued-in /
/// not-segued-out): `versionGap` = versions of the song between this shaped
/// performance and the prior same-shape one (the gating denominator), `gap` =
/// shows between (kept for reference), and `previousShowId` the prior same-shape
/// show (null prev ⇒ first such version). A narrow bridge so the hot `tracks`
/// table stays clean. Derived by the stats rebuild.
model TrackSegueRecurrence {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trackId        String              @map("track_id") @db.Uuid
  kind           SegueRecurrenceKind
  gap            Int?
  versionGap     Int?                @map("version_gap")
  previousShowId String?             @map("previous_show_id") @db.Uuid
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamp(6)

  track        Track @relation(fields: [trackId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_track_segue_recurrence_track_id")
  previousShow Show? @relation("TrackSeguePreviousShow", fields: [previousShowId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_track_segue_recurrence_previous_show_id")

  @@unique([trackId, kind], map: "track_segue_recurrence_track_kind_unique")
  @@index([previousShowId])
  @@map("track_segue_recurrence")
}

/// Directed cross-show link: the later track "completes" an earlier, unfinished
/// version of the same song. The earlier track is completed at most once, so
/// earlier_track_id is unique; both directions render a dated, linked footnote.
model TrackCompletion {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  earlierTrackId String   @unique(map: "track_completions_earlier_track_unique") @map("earlier_track_id") @db.Uuid
  laterTrackId   String   @map("later_track_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  earlierTrack Track @relation("CompletionEarlier", fields: [earlierTrackId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_track_completions_earlier_track_id")
  laterTrack   Track @relation("CompletionLater", fields: [laterTrackId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_track_completions_later_track_id")

  @@index([laterTrackId])
  @@map("track_completions")
}

